# ===== 服务器配置 =====
PORT=3000

# ===== 数据库配置 =====
# DB_PASSWORD 必须改成目标电脑上安装 MySQL 时设置的 root 密码
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123456
DB_NAME=stray_animal_rescue

# ===== JWT 密钥 =====
# 务必改成一段随机字符串，不要使用默认值，否则签发的登录令牌可被伪造。
# 生成方式（任选其一，复制输出粘贴到下面）：
#   Node:        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   PowerShell:  -join ((48..57)+(97..102) | Get-Random -Count 64 | % {[char]$_})
JWT_SECRET=please_change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ===== 上传文件目录（相对 server 目录）=====
UPLOAD_DIR=uploads

# ===== 跨域白名单（逗号分隔，留空用默认）=====
# 单端口部署（构建后由后端托管前端）为同源访问，无需配置；
# 仅当前端单独部署在其它域名/端口并跨域调用本接口时，把该域名加进来。
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
